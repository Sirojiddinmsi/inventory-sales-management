NODE_ENV=development
PORT=4000
DATABASE_URL=postgresql://inventory:inventory_password@localhost:5432/inventory_sales
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=1d
CORS_ORIGIN=http://localhost:5173
APP_TIMEZONE=Asia/Tashkent
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200

# Optional persistent product image storage.
# If IMAGEKIT_PRIVATE_KEY is empty, images are stored locally.
IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

# Frontend uses /api/v1 through Vite or Nginx proxy by default.
# Render static site should use the public API URL, for example:
# VITE_API_URL=https://tikuv-market-api.onrender.com/api/v1
VITE_API_URL=/api/v1

# Render can use "*" during first deploy, then you should tighten this
# to your frontend domain, for example:
# CORS_ORIGIN=https://tikuv-market-web.onrender.com

POSTGRES_DB=inventory_sales
POSTGRES_USER=inventory
POSTGRES_PASSWORD=inventory_password
